      </owl:ObjectProperty>
    </owl:inverseOf>
    <rdfs:label xml:lang="en">has topic</rdfs:label>
    <rdfs:comment xml:lang="en">Links a resource to a semantic topic used for retrieval and recommendation.</rdfs:comment>
  </owl:ObjectProperty>
