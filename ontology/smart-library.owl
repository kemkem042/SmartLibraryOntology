        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
        <owl:onClass rdf:resource="https://example.org/smart-library-ontology#Librarian"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:label xml:lang="en">Loan</rdfs:label>
    <rdfs:comment xml:lang="en">A transaction in which a member borrows a resource for a defined period.</rdfs:comment>
  </owl:Class>
  <owl:ObjectProperty rdf:about="https://example.org/smart-library-ontology#reservedBy">
    <rdfs:domain rdf:resource="https://example.org/smart-library-ontology#Reservation"/>
    <rdfs:range rdf:resource="https://example.org/smart-library-ontology#Member"/>
    <rdfs:label xml:lang="en">reserved by</rdfs:label>
    <rdfs:comment xml:lang="en">Links a reservation to the member who requested a resource.</rdfs:comment>
  </owl:ObjectProperty>
  <owl:Class rdf:about="https://example.org/smart-library-ontology#AcquisitionBatch">
    <rdfs:subClassOf rdf:resource="https://example.org/smart-library-ontology#LibraryEntity"/>
