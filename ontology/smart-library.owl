>
  <owl:ObjectProperty rdf:about="https://example.org/smart-library-ontology#writtenBy">
    <rdfs:domain rdf:resource="https://example.org/smart-library-ontology#LibraryResource"/>
    <rdfs:range rdf:resource="https://example.org/smart-library-ontology#Author"/>
    <rdfs:label xml:lang="en">written by</rdfs:label>
    <rdfs:comment xml:lang="en">Links a resource to its author.</rdfs:comment>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="https://example.org/smart-library-ontology#interactionType">
    <rdfs:domain rdf:resource="https://example.org/smart-library-ontology#InteractionEvent"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="en">interaction type</rdfs:label>
  </owl:DatatypeProperty>
  <slo:Loan rdf:about="https://example.org/smart-library-ontology#Loan_001">
    <slo:identifier>LN-0001</slo:identifier>
    <slo:startDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-20</slo:startDate>
    <slo:dueDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-04</slo:dueDate>
    <slo:loanedTo>
      <slo:Member rdf:about="https://example.org/smart-library-ontology#Member_Aylin_Demir">
        <slo:identifier>M-1001</slo:identifier>
        <slo:name>Aylin Demir</slo:name>
        <slo:email>aylin.demir@example.edu</slo:email>
        <slo:hasProfile rdf:resource="https://example.org/smart-library-ontology#Profile_Aylin_Demir"/>
      </slo:Member>
    </slo:loanedTo>
    <slo:loanedResource>
      <slo:PrintedBook rdf:about="https://example.org/smart-library-ontology#Book_OntologyDesign">
        <slo:identifier>B-5001</slo:identifier>
        <slo:title>Ontology Design Principles</slo:title>
        <slo:isbn>978-0-000-00001-1</slo:isbn>
        <slo:publicationYear rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">2024</slo:publicationYear>
        <slo:writtenBy rdf:resource="https://example.org/smart-library-ontology#Author_Tom_Gruber"/>
        <slo:publishedBy rdf:resource="https://example.org/smart-library-ontology#Publisher_MITPress"/>
        <slo:locatedAt rdf:resource="https://example.org/smart-library-ontology#CentralBranch"/>
        <slo:hasStatus rdf:resource="https://example.org/smart-library-ontology#OnLoan"/>
        <slo:hasTopic rdf:resource="https://example.org/smart-library-ontology#Topic_OntologyEngineering"/>
        <slo:hasTopic rdf:resource="https://example.org/smart-library-ontology#Topic_SemanticWeb"/>
        <slo:describedBy rdf:resource="https://example.org/smart-library-ontology#MetadataRecord_B5001"/>
      </slo:PrintedBook>
    </slo:loanedResource>
    <slo:processedBy>
      <slo:Librarian rdf:about="https://example.org/smart-library-ontology#Librarian_Emre_Kaya">
        <slo:identifier>L-2001</slo:identifier>
        <slo:name>Emre Kaya</slo:name>
        <slo:email>emre.kaya@example.edu</slo:email>
      </slo:Librarian>
    </slo:processedBy>
  </slo:Loan>
  <owl:DatatypeProperty rdf:about="https://example.org/smart-library-ontology#startDate">
    <rdfs:domain rdf:resource="https://example.org/smart-library-ontology#CirculationTransaction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <rdfs:label xml:lang="en">start date</rdfs:label>
  </owl:DatatypeProperty>
  <owl:Ontology rdf:about="https://example.org/smart-library-ontology">
    <dc:title xml:lang="en">Smart Library Loan Ontology</dc:title>
    <dc:creator xml:lang="en">210316051 Kemal Mert Ceyhan; 190316073 Ahmet Burak Guvercin; 210316078 Khaled ALISMAIL</dc:creator>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-27</dcterms:created>
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-14</dcterms:modified>
    <dcterms:description xml:lang="en">Version 0.2.0 of the Smart Library Loan Ontology. This phase extends the original circulation model with data acquisition provenance, topical enrichment, member profile signals, and recommendation-ready analytics for a smart library environment.</dcterms:description>
    <owl:versionInfo xml:lang="en">0.2.0 - Phase 2 extension with acquisition and personalization modules</owl:versionInfo>
  </owl:Ontology>
  <owl:ObjectProperty rdf:about="https://example.org/smart-library-ontology#hasProfile">
    <rdfs:domain rdf:resource="https://example.org/smart-library-ontology#Member"/>
    <rdfs:range rdf:resource="https://example.org/smart-library-ontology#MemberProfile"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="https://example.org/smart-library-ontology#profileOf">
        <rdfs:domain rdf:resource="https://example.org/smart-library-ontology#MemberProfile"/>
        <rdfs:range rdf:resource="https://example.org/smart-library-ontology#Member"/>
        <rdfs:label xml:lang="en">profile of</rdfs:label>
      </owl:ObjectProperty>
    </owl:inverseOf>
    <rdfs:label xml:lang="en">has profile</rdfs:label>
    <rdfs:comment xml:lang="en">Links a member to a semantic interest profile.</rdfs:comment>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="https://example.org/smart-library-ontology#retrievedAt">
    <rdfs:domain rdf:resource="https://example.org/smart-library-ontology#MetadataRecord"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <rdfs:label xml:lang="en">retrieved at</rdfs:label>
  </owl:DatatypeProperty>
  <slo:InteractionEvent rdf:about="https://example.org/smart-library-ontology#Interaction_View_001">
    <slo:identifier>INT-001</slo:identifier>
    <slo:name>E-book detail view</slo:name>
    <slo:recordsMember rdf:resource="https://example.org/smart-library-ontology#Member_Aylin_Demir"/>
    <slo:interactedWithResource>
      <slo:EBook rdf:about="https://example.org/smart-library-ontology#EBook_KnowledgeGraphs">
