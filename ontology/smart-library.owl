    <rdfs:label xml:lang="en">located at</rdfs:label>
    <rdfs:comment xml:lang="en">Links a physical resource to the branch where it is stored.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#publicationYear">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="https://example.org/smart-library-ontology#LibraryResource"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear"/>
    <rdfs:label xml:lang="en">publication year</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#Book">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://example.org/smart-library-ontology#LibraryResource"/>
    <rdfs:label xml:lang="en">Book</rdfs:label>
  </rdf:Description>
