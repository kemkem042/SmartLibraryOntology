    <slo:hasStatus rdf:resource="https://example.org/smart-library-ontology#Available"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#EBook">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://example.org/smart-library-ontology#Book"/>
    <rdfs:label xml:lang="en">E-Book</rdfs:label>
    <rdfs:comment xml:lang="en">A digital book that can be accessed electronically.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#locatedAt">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://example.org/smart-library-ontology#LibraryResource"/>
