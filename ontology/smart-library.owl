    <slo:title>Introduction to Knowledge Graphs</slo:title>
    <slo:isbn>978-0-000-00002-8</slo:isbn>
    <slo:publicationYear rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">2025</slo:publicationYear>
    <slo:publishedBy rdf:resource="https://example.org/smart-library-ontology#Publisher_MITPress"/>
