  <rdf:Description rdf:about="https://example.org/smart-library-ontology#title">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="https://example.org/smart-library-ontology#LibraryResource"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="en">title</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#branchAddress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="https://example.org/smart-library-ontology#LibraryBranch"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:label xml:lang="en">branch address</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#Person">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://example.org/smart-library-ontology#LibraryEntity"/>
    <rdfs:label xml:lang="en">Person</rdfs:label>
    <rdfs:comment xml:lang="en">A human actor related to the library system.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#LibraryBranch">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://example.org/smart-library-ontology#Organization"/>
    <rdfs:label xml:lang="en">Library Branch</rdfs:label>
    <rdfs:comment xml:lang="en">A physical branch that stores library resources and serves members.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#dueDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="https://example.org/smart-library-ontology#Loan"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <rdfs:label xml:lang="en">due date</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <dc:title xml:lang="en">Smart Library Loan Ontology</dc:title>
    <dc:creator xml:lang="en">210316051 Kemal Mert Ceyhan; 190316073 Ahmet Burak Güvercin; 210316078 Khaled ALISMAIL</dc:creator>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-27</dcterms:created>
    <dcterms:description xml:lang="en">A preliminary ontology for representing library members, resources, loans, reservations, branches, authors, and circulation status in a smart library environment.</dcterms:description>
    <owl:versionInfo xml:lang="en">0.1.0 - Initial phase draft</owl:versionInfo>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#CirculationTransaction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://example.org/smart-library-ontology#LibraryEntity"/>
    <rdfs:label xml:lang="en">Circulation Transaction</rdfs:label>
    <rdfs:comment xml:lang="en">An event-like entity representing a circulation action.</rdfs:comment>
  </rdf:Description>
</rdf:RDF>
