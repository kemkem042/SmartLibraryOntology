  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#reservedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://example.org/smart-library-ontology#Reservation"/>
    <rdfs:range rdf:resource="https://example.org/smart-library-ontology#Member"/>
    <rdfs:label xml:lang="en">reserved by</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#Librarian">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://example.org/smart-library-ontology#Person"/>
    <rdfs:label xml:lang="en">Librarian</rdfs:label>
    <rdfs:comment xml:lang="en">A library staff member who manages loans, returns, and resources.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#Reserved">
    <rdf:type rdf:resource="https://example.org/smart-library-ontology#ResourceStatus"/>
    <rdfs:label xml:lang="en">Reserved</rdfs:label>
    <slo:name>Reserved</slo:name>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#Member">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://example.org/smart-library-ontology#Person"/>
    <rdfs:label xml:lang="en">Member</rdfs:label>
    <rdfs:comment xml:lang="en">A registered user who can borrow and reserve library resources.</rdfs:comment>
    <owl:disjointWith rdf:resource="https://example.org/smart-library-ontology#Librarian"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne8ce2eb0db0c4e50bb621af3241f8defb3">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://example.org/smart-library-ontology#reservedBy"/>
    <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    <owl:onClass rdf:resource="https://example.org/smart-library-ontology#Member"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#accessUrl">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="https://example.org/smart-library-ontology#EBook"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    <rdfs:label xml:lang="en">access URL</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#Creator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://example.org/smart-library-ontology#Person"/>
    <rdfs:label xml:lang="en">Creator</rdfs:label>
    <rdfs:comment xml:lang="en">A person who contributes to the creation of a library resource.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#PrintedBook">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://example.org/smart-library-ontology#Book"/>
    <rdfs:label xml:lang="en">Printed Book</rdfs:label>
    <rdfs:comment xml:lang="en">A physical book stored at a branch.</rdfs:comment>
    <owl:disjointWith rdf:resource="https://example.org/smart-library-ontology#EBook"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#loanedTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://example.org/smart-library-ontology#Loan"/>
    <rdfs:range rdf:resource="https://example.org/smart-library-ontology#Member"/>
    <owl:inverseOf rdf:resource="https://example.org/smart-library-ontology#hasLoan"/>
    <rdfs:label xml:lang="en">loaned to</rdfs:label>
    <rdfs:comment xml:lang="en">Links a loan transaction to the member who borrowed the resource.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#CentralBranch">
    <rdf:type rdf:resource="https://example.org/smart-library-ontology#LibraryBranch"/>
    <slo:identifier>BR-001</slo:identifier>
    <slo:name>Central Library Branch</slo:name>
    <slo:branchAddress>Main Campus, Library Building</slo:branchAddress>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#Publisher">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://example.org/smart-library-ontology#Organization"/>
    <rdfs:label xml:lang="en">Publisher</rdfs:label>
    <rdfs:comment xml:lang="en">An organization that publishes a library resource.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#JournalArticle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://example.org/smart-library-ontology#LibraryResource"/>
    <rdfs:label xml:lang="en">Journal Article</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#Loan">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://example.org/smart-library-ontology#CirculationTransaction"/>
    <rdfs:subClassOf rdf:nodeID="ne8ce2eb0db0c4e50bb621af3241f8defb1"/>
    <rdfs:subClassOf rdf:nodeID="ne8ce2eb0db0c4e50bb621af3241f8defb2"/>
    <rdfs:label xml:lang="en">Loan</rdfs:label>
    <rdfs:comment xml:lang="en">A transaction in which a member borrows a resource for a defined period.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#Loan_001">
    <rdf:type rdf:resource="https://example.org/smart-library-ontology#Loan"/>
    <slo:identifier>LN-0001</slo:identifier>
    <slo:startDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-20</slo:startDate>
    <slo:dueDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-04</slo:dueDate>
    <slo:loanedTo rdf:resource="https://example.org/smart-library-ontology#Member_Aylin_Demir"/>
    <slo:loanedResource rdf:resource="https://example.org/smart-library-ontology#Book_OntologyDesign"/>
    <slo:processedBy rdf:resource="https://example.org/smart-library-ontology#Librarian_Emre_Kaya"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#OnLoan">
    <rdf:type rdf:resource="https://example.org/smart-library-ontology#ResourceStatus"/>
    <rdfs:label xml:lang="en">On Loan</rdfs:label>
    <slo:name>On loan</slo:name>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#hasStatus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://example.org/smart-library-ontology#LibraryResource"/>
    <rdfs:range rdf:resource="https://example.org/smart-library-ontology#ResourceStatus"/>
    <rdfs:label xml:lang="en">has status</rdfs:label>
    <rdfs:comment xml:lang="en">Links a resource to its current availability status.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#ResourceStatus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://example.org/smart-library-ontology#LibraryEntity"/>
    <rdfs:label xml:lang="en">Resource Status</rdfs:label>
    <rdfs:comment xml:lang="en">Controlled status values for library resources.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#LibraryResource">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://example.org/smart-library-ontology#LibraryEntity"/>
    <rdfs:label xml:lang="en">Library Resource</rdfs:label>
    <rdfs:comment xml:lang="en">A resource that can be catalogued, borrowed, or reserved.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne8ce2eb0db0c4e50bb621af3241f8defb2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://example.org/smart-library-ontology#loanedResource"/>
    <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    <owl:onClass rdf:resource="https://example.org/smart-library-ontology#LibraryResource"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#Reservation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://example.org/smart-library-ontology#CirculationTransaction"/>
    <rdfs:subClassOf rdf:nodeID="ne8ce2eb0db0c4e50bb621af3241f8defb3"/>
    <rdfs:subClassOf rdf:nodeID="ne8ce2eb0db0c4e50bb621af3241f8defb4"/>
    <rdfs:label xml:lang="en">Reservation</rdfs:label>
    <rdfs:comment xml:lang="en">A transaction in which a member requests a resource before borrowing it.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://example.org/smart-library-ontology#startDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="https://example.org/smart-library-ontology#CirculationTransaction"/>
