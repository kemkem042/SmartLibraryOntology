        <slo:isbn>978-0-000-00002-8</slo:isbn>
        <slo:publicationYear rdf:datatype="http://www.w3.org/2001/XMLSchema#gYear">2025</slo:publicationYear>
        <slo:publishedBy rdf:resource="https://example.org/smart-library-ontology#Publisher_MITPress"/>
        <slo:accessUrl rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://example.org/ebooks/knowledge-graphs</slo:accessUrl>
        <slo:hasStatus rdf:resource="https://example.org/smart-library-ontology#Available"/>
        <slo:hasTopic rdf:resource="https://example.org/smart-library-ontology#Topic_KnowledgeGraphs"/>
        <slo:hasTopic rdf:resource="https://example.org/smart-library-ontology#Topic_SemanticWeb"/>
        <slo:describedBy rdf:resource="https://example.org/smart-library-ontology#MetadataRecord_EB5002"/>
      </slo:EBook>
    </slo:interactedWithResource>
    <slo:interactionType>view</slo:interactionType>
  </slo:InteractionEvent>
