  <owl:Class rdf:about="https://example.org/smart-library-ontology#LibraryBranch">
    <rdfs:subClassOf rdf:resource="https://example.org/smart-library-ontology#Organization"/>
    <rdfs:label xml:lang="en">Library Branch</rdfs:label>
    <rdfs:comment xml:lang="en">A physical branch that stores library resources and serves members.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://example.org/smart-library-ontology#Member">
