@prefix : <https://example.org/smart-library-ontology#> .
@prefix slo: <https://example.org/smart-library-ontology#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/smart-library-ontology>
    a owl:Ontology ;
    dc:title "Smart Library Loan Ontology"@en ;
    dc:creator "210316051 Kemal Mert Ceyhan; 190316073 Ahmet Burak Guvercin; 210316078 Khaled ALISMAIL"@en ;
    dcterms:created "2026-04-27"^^xsd:date ;
    dcterms:modified "2026-05-14"^^xsd:date ;
    dcterms:description "Version 0.2.0 of the Smart Library Loan Ontology. This phase extends the original circulation model with data acquisition provenance, topical enrichment, member profile signals, and recommendation-ready analytics for a smart library environment."@en ;
    owl:versionInfo "0.2.0 - Phase 2 extension with acquisition and personalization modules"@en .

#################################################################
# Classes
#################################################################

slo:LibraryEntity a owl:Class ;
    rdfs:label "Library Entity"@en ;
    rdfs:comment "Top-level class for entities represented in the smart library domain."@en .

slo:Person a owl:Class ;
    rdfs:subClassOf slo:LibraryEntity ;
    rdfs:label "Person"@en ;
    rdfs:comment "A human actor related to the library system."@en .

slo:Member a owl:Class ;
    rdfs:subClassOf slo:Person ;
    rdfs:label "Member"@en ;
    rdfs:comment "A registered user who can borrow, reserve, and receive personalized recommendations for library resources."@en .

slo:Librarian a owl:Class ;
    rdfs:subClassOf slo:Person ;
    rdfs:label "Librarian"@en ;
    rdfs:comment "A library staff member who manages loans, returns, and resources."@en .

slo:Creator a owl:Class ;
    rdfs:subClassOf slo:Person ;
    rdfs:label "Creator"@en ;
    rdfs:comment "A person who contributes to the creation of a library resource."@en .

slo:Author a owl:Class ;
    rdfs:subClassOf slo:Creator ;
    rdfs:label "Author"@en ;
    rdfs:comment "A creator who writes a book or article."@en .

slo:Organization a owl:Class ;
    rdfs:subClassOf slo:LibraryEntity ;
    rdfs:label "Organization"@en .

slo:Publisher a owl:Class ;
    rdfs:subClassOf slo:Organization, schema:Organization ;
    rdfs:label "Publisher"@en ;
    rdfs:comment "An organization that publishes a library resource."@en .

slo:LibraryBranch a owl:Class ;
    rdfs:subClassOf slo:Organization ;
    rdfs:label "Library Branch"@en ;
    rdfs:comment "A physical branch that stores library resources and serves members."@en .

slo:DataSource a owl:Class ;
    rdfs:subClassOf slo:LibraryEntity ;
    rdfs:label "Data Source"@en ;
    rdfs:comment "A source used during data acquisition, such as an API, catalog export, spreadsheet, or document collection."@en .

slo:AcquisitionBatch a owl:Class ;
    rdfs:subClassOf slo:LibraryEntity ;
    rdfs:label "Acquisition Batch"@en ;
    rdfs:comment "A bounded data collection and preprocessing run used to populate ontology instances."@en .

slo:MetadataRecord a owl:Class ;
    rdfs:subClassOf slo:LibraryEntity ;
    rdfs:label "Metadata Record"@en ;
    rdfs:comment "A structured metadata record that documents where and when a resource description was acquired."@en .

slo:Topic a owl:Class ;
    rdfs:subClassOf slo:LibraryEntity ;
    rdfs:label "Topic"@en ;
    rdfs:comment "A semantic subject or keyword used to connect resources, user interests, and recommendations."@en .

slo:LibraryResource a owl:Class ;
    rdfs:subClassOf slo:LibraryEntity, schema:CreativeWork ;
    rdfs:label "Library Resource"@en ;
    rdfs:comment "A resource that can be catalogued, borrowed, reserved, or recommended."@en .

slo:Book a owl:Class ;
    rdfs:subClassOf slo:LibraryResource, schema:Book ;
    rdfs:label "Book"@en .

slo:PrintedBook a owl:Class ;
    rdfs:subClassOf slo:Book ;
    rdfs:label "Printed Book"@en ;
    rdfs:comment "A physical book stored at a branch."@en .

slo:EBook a owl:Class ;
    rdfs:subClassOf slo:Book, schema:Book ;
    rdfs:label "E-Book"@en ;
    rdfs:comment "A digital book that can be accessed electronically."@en .

slo:JournalArticle a owl:Class ;
    rdfs:subClassOf slo:LibraryResource ;
    rdfs:label "Journal Article"@en .

slo:MemberProfile a owl:Class ;
    rdfs:subClassOf slo:LibraryEntity ;
    rdfs:label "Member Profile"@en ;
    rdfs:comment "A lightweight semantic profile that stores a member's interest topics for personalization and recommendation."@en .

slo:InteractionEvent a owl:Class ;
    rdfs:subClassOf slo:LibraryEntity ;
    rdfs:label "Interaction Event"@en ;
    rdfs:comment "An observed user interaction such as viewing, searching, bookmarking, or clicking a resource."@en .

slo:Recommendation a owl:Class ;
    rdfs:subClassOf slo:LibraryEntity ;
    rdfs:label "Recommendation"@en ;
    rdfs:comment "A recommendation candidate connecting a member to a resource using topical or behavioral evidence."@en .

slo:CirculationTransaction a owl:Class ;
    rdfs:subClassOf slo:LibraryEntity ;
    rdfs:label "Circulation Transaction"@en ;
    rdfs:comment "An event-like entity representing a circulation action."@en .

slo:Loan a owl:Class ;
    rdfs:subClassOf slo:CirculationTransaction ;
    rdfs:label "Loan"@en ;
    rdfs:comment "A transaction in which a member borrows a resource for a defined period."@en .

slo:Reservation a owl:Class ;
    rdfs:subClassOf slo:CirculationTransaction ;
    rdfs:label "Reservation"@en ;
    rdfs:comment "A transaction in which a member requests a resource before borrowing it."@en .

slo:ResourceStatus a owl:Class ;
    rdfs:subClassOf slo:LibraryEntity ;
    rdfs:label "Resource Status"@en ;
    rdfs:comment "Controlled status values for library resources."@en .

#################################################################
# Object Properties
#################################################################

slo:hasLoan a owl:ObjectProperty ;
    rdfs:domain slo:Member ;
    rdfs:range slo:Loan ;
    rdfs:label "has loan"@en ;
    rdfs:comment "Links a member to a loan transaction."@en .

slo:loanedTo a owl:ObjectProperty ;
    rdfs:domain slo:Loan ;
    rdfs:range slo:Member ;
    owl:inverseOf slo:hasLoan ;
    rdfs:label "loaned to"@en ;
    rdfs:comment "Links a loan transaction to the member who borrowed the resource."@en .

slo:loanedResource a owl:ObjectProperty ;
    rdfs:domain slo:Loan ;
    rdfs:range slo:LibraryResource ;
    rdfs:label "loaned resource"@en ;
    rdfs:comment "Links a loan transaction to the borrowed resource."@en .

slo:reservedBy a owl:ObjectProperty ;
    rdfs:domain slo:Reservation ;
    rdfs:range slo:Member ;
    rdfs:label "reserved by"@en ;
    rdfs:comment "Links a reservation to the member who requested a resource."@en .

slo:reservedResource a owl:ObjectProperty ;
    rdfs:domain slo:Reservation ;
    rdfs:range slo:LibraryResource ;
    rdfs:label "reserved resource"@en ;
    rdfs:comment "Links a reservation to the requested resource."@en .

slo:processedBy a owl:ObjectProperty ;
    rdfs:domain slo:CirculationTransaction ;
    rdfs:range slo:Librarian ;
    rdfs:label "processed by"@en ;
    rdfs:comment "Links a transaction to the librarian responsible for processing it."@en .

slo:locatedAt a owl:ObjectProperty ;
    rdfs:domain slo:LibraryResource ;
    rdfs:range slo:LibraryBranch ;
    rdfs:label "located at"@en ;
    rdfs:comment "Links a physical resource to the branch where it is stored."@en .

slo:writtenBy a owl:ObjectProperty ;
    rdfs:domain slo:LibraryResource ;
    rdfs:range slo:Author ;
    rdfs:label "written by"@en ;
    rdfs:comment "Links a resource to its author."@en .

slo:publishedBy a owl:ObjectProperty ;
    rdfs:domain slo:LibraryResource ;
    rdfs:range slo:Publisher ;
    rdfs:label "published by"@en ;
    rdfs:comment "Links a resource to its publisher."@en .

slo:hasStatus a owl:ObjectProperty ;
    rdfs:domain slo:LibraryResource ;
    rdfs:range slo:ResourceStatus ;
    rdfs:label "has status"@en ;
    rdfs:comment "Links a resource to its current availability status."@en .

slo:hasTopic a owl:ObjectProperty ;
    rdfs:domain slo:LibraryResource ;
    rdfs:range slo:Topic ;
    rdfs:subPropertyOf dcterms:subject ;
    owl:inverseOf slo:topicOf ;
    rdfs:label "has topic"@en ;
    rdfs:comment "Links a resource to a semantic topic used for retrieval and recommendation."@en .

slo:topicOf a owl:ObjectProperty ;
    rdfs:domain slo:Topic ;
    rdfs:range slo:LibraryResource ;
    rdfs:label "topic of"@en .

slo:describedBy a owl:ObjectProperty ;
    rdfs:domain slo:LibraryResource ;
    rdfs:range slo:MetadataRecord ;
    owl:inverseOf slo:describesResource ;
    rdfs:label "described by"@en ;
    rdfs:comment "Links a resource to the metadata record from which it was populated or curated."@en .

slo:describesResource a owl:ObjectProperty ;
    rdfs:domain slo:MetadataRecord ;
    rdfs:range slo:LibraryResource ;
    rdfs:label "describes resource"@en ;
    rdfs:comment "Links a metadata record to the resource it describes."@en .

slo:retrievedFromSource a owl:ObjectProperty ;
    rdfs:domain slo:MetadataRecord ;
    rdfs:range slo:DataSource ;
    rdfs:label "retrieved from source"@en ;
    rdfs:comment "Links a metadata record to the source from which the data were collected."@en .

slo:generatedInBatch a owl:ObjectProperty ;
    rdfs:domain slo:MetadataRecord ;
    rdfs:range slo:AcquisitionBatch ;
    rdfs:label "generated in batch"@en ;
    rdfs:comment "Links a metadata record to the data acquisition batch that produced or refreshed it."@en .

slo:hasProfile a owl:ObjectProperty ;
    rdfs:domain slo:Member ;
    rdfs:range slo:MemberProfile ;
    owl:inverseOf slo:profileOf ;
    rdfs:label "has profile"@en ;
    rdfs:comment "Links a member to a semantic interest profile."@en .

slo:profileOf a owl:ObjectProperty ;
    rdfs:domain slo:MemberProfile ;
    rdfs:range slo:Member ;
    rdfs:label "profile of"@en .

slo:hasInterestTopic a owl:ObjectProperty ;
    rdfs:domain slo:MemberProfile ;
    rdfs:range slo:Topic ;
    rdfs:label "has interest topic"@en ;
    rdfs:comment "Links a member profile to one or more topics representing inferred or observed interests."@en .

slo:recordsMember a owl:ObjectProperty ;
    rdfs:domain slo:InteractionEvent ;
    rdfs:range slo:Member ;
    rdfs:label "records member"@en ;
    rdfs:comment "Links an interaction event to the member who performed it."@en .

slo:interactedWithResource a owl:ObjectProperty ;
    rdfs:domain slo:InteractionEvent ;
    rdfs:range slo:LibraryResource ;
    rdfs:label "interacted with resource"@en ;
    rdfs:comment "Links an interaction event to the resource that was viewed or searched."@en .

slo:recommendedFor a owl:ObjectProperty ;
    rdfs:domain slo:Recommendation ;
    rdfs:range slo:Member ;
    rdfs:label "recommended for"@en ;
    rdfs:comment "Links a recommendation candidate to the target member."@en .

slo:recommendedResource a owl:ObjectProperty ;
    rdfs:domain slo:Recommendation ;
    rdfs:range slo:LibraryResource ;
    rdfs:label "recommended resource"@en ;
    rdfs:comment "Links a recommendation candidate to the resource proposed for the member."@en .

#################################################################
# Data Properties
#################################################################

slo:identifier a owl:DatatypeProperty ;
    rdfs:domain slo:LibraryEntity ;
    rdfs:range xsd:string ;
    rdfs:label "identifier"@en .

slo:name a owl:DatatypeProperty ;
    rdfs:domain slo:LibraryEntity ;
    rdfs:range xsd:string ;
    owl:equivalentProperty schema:name ;
    rdfs:label "name"@en .

slo:title a owl:DatatypeProperty ;
    rdfs:domain slo:LibraryResource ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf dc:title ;
    rdfs:label "title"@en .

slo:isbn a owl:DatatypeProperty ;
    rdfs:domain slo:Book ;
    rdfs:range xsd:string ;
    owl:equivalentProperty schema:isbn ;
    rdfs:label "ISBN"@en .

slo:publicationYear a owl:DatatypeProperty ;
    rdfs:domain slo:LibraryResource ;
    rdfs:range xsd:gYear ;
    rdfs:label "publication year"@en .

slo:startDate a owl:DatatypeProperty ;
    rdfs:domain slo:CirculationTransaction ;
    rdfs:range xsd:date ;
    rdfs:label "start date"@en .

slo:dueDate a owl:DatatypeProperty ;
    rdfs:domain slo:Loan ;
    rdfs:range xsd:date ;
    rdfs:label "due date"@en .

slo:returnDate a owl:DatatypeProperty ;
    rdfs:domain slo:Loan ;
    rdfs:range xsd:date ;
    rdfs:label "return date"@en .

slo:email a owl:DatatypeProperty ;
    rdfs:domain slo:Person ;
    rdfs:range xsd:string ;
    rdfs:label "email"@en .

slo:branchAddress a owl:DatatypeProperty ;
    rdfs:domain slo:LibraryBranch ;
    rdfs:range xsd:string ;
    rdfs:label "branch address"@en .

slo:accessUrl a owl:DatatypeProperty ;
    rdfs:domain slo:EBook ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf schema:url ;
    rdfs:label "access URL"@en .

slo:sourceUrl a owl:DatatypeProperty ;
    rdfs:domain slo:DataSource ;
    rdfs:range xsd:anyURI ;
    rdfs:subPropertyOf schema:url ;
    rdfs:label "source URL"@en .

slo:retrievedAt a owl:DatatypeProperty ;
    rdfs:domain slo:MetadataRecord ;
    rdfs:range xsd:dateTime ;
    rdfs:label "retrieved at"@en .

slo:confidenceScore a owl:DatatypeProperty ;
    rdfs:domain slo:MetadataRecord ;
    rdfs:range xsd:decimal ;
    rdfs:label "confidence score"@en .

slo:interactionType a owl:DatatypeProperty ;
    rdfs:domain slo:InteractionEvent ;
    rdfs:range xsd:string ;
    rdfs:label "interaction type"@en .

slo:profileScore a owl:DatatypeProperty ;
    rdfs:domain slo:Recommendation ;
    rdfs:range xsd:decimal ;
    rdfs:label "profile score"@en .

#################################################################
# Axioms and Constraints
#################################################################

slo:Loan rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty slo:loanedTo ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onClass slo:Member
    ],
    [ a owl:Restriction ;
      owl:onProperty slo:loanedResource ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onClass slo:LibraryResource
    ],
    [ a owl:Restriction ;
      owl:onProperty slo:processedBy ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onClass slo:Librarian
    ] .

slo:Reservation rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty slo:reservedBy ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onClass slo:Member
    ],
    [ a owl:Restriction ;
      owl:onProperty slo:reservedResource ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onClass slo:LibraryResource
    ],
    [ a owl:Restriction ;
      owl:onProperty slo:processedBy ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onClass slo:Librarian
    ] .

slo:MetadataRecord rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty slo:describesResource ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onClass slo:LibraryResource
    ],
    [ a owl:Restriction ;
      owl:onProperty slo:retrievedFromSource ;
      owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onClass slo:DataSource
    ] .

slo:Recommendation rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty slo:recommendedFor ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onClass slo:Member
    ],
    [ a owl:Restriction ;
      owl:onProperty slo:recommendedResource ;
      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
      owl:onClass slo:LibraryResource
    ] .

slo:Member owl:disjointWith slo:Librarian .
slo:PrintedBook owl:disjointWith slo:EBook .

#################################################################
# Individuals
#################################################################

slo:Available a slo:ResourceStatus ;
    rdfs:label "Available"@en ;
    slo:name "Available" .

slo:OnLoan a slo:ResourceStatus ;
    rdfs:label "On Loan"@en ;
    slo:name "On loan" .

slo:Reserved a slo:ResourceStatus ;
    rdfs:label "Reserved"@en ;
    slo:name "Reserved" .

slo:CentralBranch a slo:LibraryBranch ;
    slo:identifier "BR-001" ;
    slo:name "Central Library Branch" ;
    slo:branchAddress "Main Campus, Library Building" .

slo:Member_Aylin_Demir a slo:Member ;
    slo:identifier "M-1001" ;
    slo:name "Aylin Demir" ;
    slo:email "aylin.demir@example.edu" ;
    slo:hasProfile slo:Profile_Aylin_Demir .

slo:Librarian_Emre_Kaya a slo:Librarian ;
    slo:identifier "L-2001" ;
    slo:name "Emre Kaya" ;
    slo:email "emre.kaya@example.edu" .

slo:Author_Tom_Gruber a slo:Author ;
    slo:identifier "A-3001" ;
    slo:name "Tom Gruber" .

slo:Publisher_MITPress a slo:Publisher ;
    slo:identifier "P-4001" ;
    slo:name "MIT Press" .

slo:DataSource_OpenLibraryAPI a slo:DataSource ;
    slo:identifier "SRC-001" ;
    slo:name "Open Library API" ;
    slo:sourceUrl "https://openlibrary.org/developers/api"^^xsd:anyURI .

slo:DataSource_GoogleBooksAPI a slo:DataSource ;
    slo:identifier "SRC-002" ;
    slo:name "Google Books API" ;
    slo:sourceUrl "https://developers.google.com/books"^^xsd:anyURI .

slo:DataSource_DepartmentSeedSheet a slo:DataSource ;
    slo:identifier "SRC-003" ;
    slo:name "Department Seed Spreadsheet" ;
    slo:sourceUrl "https://example.org/internal/seed-sheet"^^xsd:anyURI .

slo:AcquisitionBatch_2026_05_Phase2 a slo:AcquisitionBatch ;
    slo:identifier "BATCH-2026-05-P2" ;
    slo:name "Phase 2 metadata integration batch" .

slo:Topic_OntologyEngineering a slo:Topic ;
    slo:identifier "TOP-001" ;
    slo:name "Ontology Engineering" .

slo:Topic_KnowledgeGraphs a slo:Topic ;
    slo:identifier "TOP-002" ;
    slo:name "Knowledge Graphs" .

slo:Topic_SemanticWeb a slo:Topic ;
    slo:identifier "TOP-003" ;
    slo:name "Semantic Web" .

slo:Book_OntologyDesign a slo:PrintedBook ;
    slo:identifier "B-5001" ;
    slo:title "Ontology Design Principles" ;
    slo:isbn "978-0-000-00001-1" ;
    slo:publicationYear "2024"^^xsd:gYear ;
