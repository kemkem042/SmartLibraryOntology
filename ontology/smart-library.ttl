slo:Interaction_Search_001 a slo:InteractionEvent ;
    slo:identifier "INT-002" ;
    slo:name "Semantic web topic search" ;
    slo:recordsMember slo:Member_Aylin_Demir ;
    slo:interactedWithResource slo:Book_OntologyDesign ;
    slo:interactionType "search" .

slo:Loan_001 a slo:Loan ;
