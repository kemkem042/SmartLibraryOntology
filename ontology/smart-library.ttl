    slo:publishedBy slo:Publisher_MITPress ;
    slo:locatedAt slo:CentralBranch ;
    slo:hasStatus slo:OnLoan ;
    slo:hasTopic slo:Topic_OntologyEngineering, slo:Topic_SemanticWeb ;
    slo:describedBy slo:MetadataRecord_B5001 .

slo:EBook_KnowledgeGraphs a slo:EBook ;
    slo:identifier "EB-5002" ;
    slo:title "Introduction to Knowledge Graphs" ;
    slo:isbn "978-0-000-00002-8" ;
    slo:publicationYear "2025"^^xsd:gYear ;
    slo:publishedBy slo:Publisher_MITPress ;
    slo:accessUrl "https://example.org/ebooks/knowledge-graphs"^^xsd:anyURI ;
    slo:hasStatus slo:Available ;
    slo:hasTopic slo:Topic_KnowledgeGraphs, slo:Topic_SemanticWeb ;
    slo:describedBy slo:MetadataRecord_EB5002 .

slo:MetadataRecord_B5001 a slo:MetadataRecord ;
    slo:identifier "MR-5001" ;
    slo:name "Metadata record for Ontology Design Principles" ;
    slo:describesResource slo:Book_OntologyDesign ;
    slo:retrievedFromSource slo:DataSource_OpenLibraryAPI, slo:DataSource_DepartmentSeedSheet ;
    slo:generatedInBatch slo:AcquisitionBatch_2026_05_Phase2 ;
    slo:retrievedAt "2026-05-10T10:00:00"^^xsd:dateTime ;
    slo:confidenceScore "0.95"^^xsd:decimal .

slo:MetadataRecord_EB5002 a slo:MetadataRecord ;
    slo:identifier "MR-5002" ;
    slo:name "Metadata record for Introduction to Knowledge Graphs" ;
    slo:describesResource slo:EBook_KnowledgeGraphs ;
    slo:retrievedFromSource slo:DataSource_GoogleBooksAPI, slo:DataSource_DepartmentSeedSheet ;
    slo:generatedInBatch slo:AcquisitionBatch_2026_05_Phase2 ;
    slo:retrievedAt "2026-05-10T10:15:00"^^xsd:dateTime ;
    slo:confidenceScore "0.92"^^xsd:decimal .

slo:Profile_Aylin_Demir a slo:MemberProfile ;
    slo:identifier "PRO-1001" ;
    slo:name "Aylin Demir semantic interest profile" ;
    slo:profileOf slo:Member_Aylin_Demir ;
    slo:hasInterestTopic slo:Topic_KnowledgeGraphs, slo:Topic_SemanticWeb .

slo:Interaction_View_001 a slo:InteractionEvent ;
    slo:identifier "INT-001" ;
    slo:name "E-book detail view" ;
